{
  "name": "styrby",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cli": "pnpm --filter styrby-cli",
    "mobile": "pnpm --filter styrby-mobile",
    "web": "pnpm --filter styrby-web",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r run typecheck --if-present",
    "build": "pnpm -r run build --if-present",
    "test": "pnpm -r run test --if-present",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.0",
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "rollup": ">=4.59.0",
      "tar": ">=7.5.10"
    }
  }
}
