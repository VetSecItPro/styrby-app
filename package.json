{
  "name": "styrby",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cli": "pnpm --filter styrby-cli",
    "mobile": "pnpm --filter styrby-mobile",
    "web": "pnpm --filter styrby-web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "test": "turbo run test",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist .turbo packages/*/.turbo",
    "size": "size-limit",
    "size:json": "size-limit --json"
  },
  "devDependencies": {
    "@size-limit/file": "^11.1.6",
    "size-limit": "^11.1.6",
    "turbo": "2.9.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.0",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "@xmldom/xmldom": ">=0.8.12",
      "rollup": ">=4.59.0",
      "tar": ">=7.5.13",
      "minimatch": ">=9.0.7",
      "undici": ">=7.24.5",
      "serialize-javascript": ">=7.0.5",
      "express-rate-limit": ">=8.2.2",
      "qs": ">=6.14.2",
      "mailparser": ">=3.9.3",
      "@tootallnate/once": ">=3.0.1",
      "path-to-regexp": ">=8.4.0",
      "picomatch@^2": "^2.3.2",
      "picomatch@^3": "^3.0.2",
      "picomatch@^4": "^4.0.4",
      "picomatch@^4.0.3": "^4.0.4",
      "picomatch@^4.0.2": "^4.0.4",
      "tinyglobby>picomatch": "^4.0.4",
      "vite>picomatch": "^4.0.4",
      "rollup>picomatch": "^4.0.4",
      "fdir>picomatch": "^4.0.4",
      "vitest>picomatch": "^4.0.4",
      "anymatch>picomatch": "^2.3.2",
      "node-forge": ">=1.4.0",
      "brace-expansion": ">=5.0.5",
      "nodemailer": ">=8.0.5",
      "follow-redirects": ">=1.16.0",
      "lodash": ">=4.18.0",
      "vite": ">=7.3.2",
      "react-native-css-interop": "0.1.22"
    },
    "packageExtensions": {
      "@testing-library/react-native@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "expo-router@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "@expo/vector-icons@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "react-native-css-interop@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "@react-navigation/core@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "expo-modules-core@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "expo-camera@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "react-native-pager-view@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "react-native-svg@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      },
      "react-native-gesture-handler@*": {
        "peerDependencies": {
          "@types/react": "~18.3.0"
        }
      }
    }
  }
}
