{
  "name": "styrby-mobile",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "prebuild": "node scripts/validate-config.mjs && expo prebuild",
    "build:dev": "npm run validate && eas build --profile development",
    "build:preview": "npm run validate && eas build --profile preview",
    "build:prod": "npm run validate && eas build --profile production",
    "validate": "node scripts/validate-config.mjs",
    "generate-assets": "node scripts/generate-placeholders.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ app/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e:cold-start": "detox test --configuration android.emu.release",
    "e2e:cold-start:ios": "detox test --configuration ios.sim.release",
    "e2e:build:cold-start": "detox build --configuration android.emu.release",
    "e2e:build:cold-start:ios": "detox build --configuration ios.sim.release"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "~15.1.1",
    "@react-native-community/netinfo": "11.4.1",
    "@sentry/react-native": "~7.2.0",
    "@styrby/shared": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "assert": "2.1.0",
    "clsx": "^2.1.1",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "^15.0.8",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-passkey": "0.3.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "nativewind": "4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "1.11.0",
    "react-native-pager-view": "6.9.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "tailwind-merge": "^3.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@eslint/js": "^9.20.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "@types/react-test-renderer": "~18.3.0",
    "detox": "^20.27.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.30.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@styrby/shared"
        ]
      }
    }
  }
}
