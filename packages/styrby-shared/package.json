{
  "name": "@styrby/shared",
  "version": "0.1.0",
  "description": "Shared types and utilities for Styrby",
  "author": "Steel Motion LLC",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./encryption": {
      "types": "./dist/encryption.d.ts",
      "import": "./dist/encryption.js"
    },
    "./relay": {
      "types": "./dist/relay/index.d.ts",
      "import": "./dist/relay/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing/index.d.ts",
      "import": "./dist/pricing/index.js"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./tokenizers": {
      "types": "./dist/tokenizers/index.d.ts",
      "import": "./dist/tokenizers/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "libsodium-wrappers": "^0.7.15",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.15.18",
    "@vitest/coverage-v8": "^3.2.4",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
