# FIX-060: Pin exact dependency versions
# WHY: Prevents semver ranges from pulling in broken or compromised patches.
# Every dependency update is explicit and reviewable in diffs.
save-exact=true

# WHY: Hoist most @types/* packages to root so tooling (ESLint, Jest, etc.)
# can find them without being inside a package's own node_modules. However,
# @types/react and @types/react-dom are EXCLUDED from hoisting because
# styrby-mobile uses React 18 types (~18.3.0) while styrby-web uses React 19
# types (^19.0.0). If either were hoisted to root, the wrong version would be
# picked up by the other package, causing TS2786 ("cannot be used as a JSX
# component") and ReactNode/bigint incompatibilities. Each package must resolve
# its own local copy of these types.
public-hoist-pattern[]=@types/node
public-hoist-pattern[]=@types/jest
public-hoist-pattern[]=@types/bcrypt
public-hoist-pattern[]=@types/web-push
public-hoist-pattern[]=@types/eslint
public-hoist-pattern[]=@types/estree
public-hoist-pattern[]=@types/json-schema
