# FIX-060: Pin exact dependency versions
# WHY: Prevents semver ranges from pulling in broken or compromised patches.
# Every dependency update is explicit and reviewable in diffs.
save-exact=true

# WHY: pnpm's strict module isolation creates separate @types/react copies
# per package. Expo SDK 52 components (Ionicons, Stack, PagerView, etc.) were
# compiled against one @types/react instance, while our code resolves another.
# This causes TS2786 ("cannot be used as a JSX component") because the
# Component.refs property type doesn't match between copies. Hoisting @types
# ensures a single shared copy across all packages.
public-hoist-pattern[]=@types/*
